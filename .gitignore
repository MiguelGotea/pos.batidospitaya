# Excluir TODO en la raíz EXCEPTO lo permitido
/*
!/.gitignore
!/modulos/
!/.scripts/
!/README.md
!/.github/
!/core/
!/docs/
!/.agent/
# Archivos raíz del dominio POS
!/index.php
!/login.php
!/logout.php
# Las 3 carpetas compartidas (core, docs, .agent) son trackeadas en GitHub
# pero excluidas del host vía --exclude en deploy-pos.yml

# Incluir todo en modulos
!/modulos/**

# Excluir uploads dentro de módulos
/modulos/*/uploads/
/modulos/uploads/

# Excluir todo dentro de uploads (pero mantener las carpetas)
